# Template paper trading — copier en .env.paper puis remplir.
#   cp .env.paper.example .env.paper
#
# Le paper N'A PAS besoin des clés Hyperliquid (le PaperTrader ne passe aucun ordre)
# ni de MONGO_URL (défini dans docker-compose.paper.yml → Mongo local).
#
# Telegram : OPTIONNEL. Laisser vide = pas de notifications. Pour des alertes paper
# séparées, créer un 2e bot Telegram (BotFather) et coller token + chat id ici.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
